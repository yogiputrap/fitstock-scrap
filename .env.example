# Target URL (with hash so we land on the right section)
TARGET_URL=https://fitstock.id/#sec-spil

# Polling interval in milliseconds (10s as requested)
POLL_INTERVAL_MS=10000

# WhatsApp numbers (digits only, international format without +)
# WA_SENDER is the number you scan QR with (your WA Business number)
WA_SENDER=6282310119696
# WA_TARGET is where alerts are delivered
WA_TARGET=6287881188102

# HTTP server port for QR / health (Dokploy will expose this)
# Host port exposed on the Dokploy server (container always listens on HTTP_PORT internally)
# Change this if 3100 is also taken on your server
HOST_PORT=3100

# Internal container port
HTTP_PORT=3000

# If true, push all currently listed picks on first run.
# If false (default), the first poll is treated as baseline and only
# picks that appear afterwards are sent to WhatsApp.
NOTIFY_ON_STARTUP=false

# Log level (trace|debug|info|warn|error)
LOG_LEVEL=info

# Where Playwright + Baileys state is persisted
DATA_DIR=/data
